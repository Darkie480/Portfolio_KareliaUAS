<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:viewmodels="clr-namespace:GestationTracker.ViewModels"
             x:Class="GestationTracker.Views.CatViews.CatDetailPage"
             x:DataType="viewmodels:CatDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource Primary}">


    <Shell.TitleView>
        <Label Text="{Binding Title}"
               FontSize="20"
               FontAttributes="Bold"
               VerticalTextAlignment="Center"
               HorizontalTextAlignment="Center"/>
    </Shell.TitleView>

    <ScrollView>

        
        <VerticalStackLayout Padding="20" Spacing="20">


            <Border Stroke="Black" StrokeThickness="1" Padding="10" 
                    HorizontalOptions="Center">
                <Image Source="{Binding Cat.ImageUrl}"
                       WidthRequest="420" HeightRequest="300" Aspect="AspectFit"/>
            </Border>

            <VerticalStackLayout Spacing="5">
                <Label Text="{Binding Cat.RegistrationName}" FontSize="20" FontAttributes="Bold"/>
                <Label Text="{Binding Cat.Name}" FontSize="18" FontFamily="Courier"/>

                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto"
                      ColumnSpacing="12" RowSpacing="10">
                    <Label Grid.Row="0" Grid.Column="0" Text="Kissan ikä:" FontSize="18"/>
                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Cat.AgeSpecific}" FontSize="18" />
                </Grid>
            </VerticalStackLayout>


            <BoxView HeightRequest="1" Color="Black"/>

            <Label Text="{Binding Cat.DateAdded}" FontSize="9" FontAttributes="Italic"/>
            <Label Text="{Binding Cat.Breed}" FontSize="16" FontAttributes="Italic"/>

            <Frame Padding="10" CornerRadius="10" HorizontalOptions="Center"
                   IsVisible="{Binding IsRegistered}"
                   BackgroundColor="{StaticResource PrimaryDark}"
                   BorderColor="Black">
                <Label Text="{Binding Cat.RegistrationNumber}" FontSize="20" FontAttributes="Bold"/>
            </Frame>

            <Frame Padding="10" CornerRadius="10" HorizontalOptions="Center"
                   IsVisible="{Binding IsInsured}" 
                   BackgroundColor="{StaticResource PrimaryDark}"
                   BorderColor="Black">
                <Label FontSize="16" FontAttributes="Bold" TextColor="Black">
                    <Label.Text>
                        <MultiBinding>
                            <MultiBinding.StringFormat>
                                {0} | {1}
                            </MultiBinding.StringFormat>
                            <Binding Path="Cat.InsuranceNumber"/>
                            <Binding Path="Cat.InsuranceCompany"/>
                        </MultiBinding>
                    </Label.Text>
                </Label>
            </Frame>



            <Grid ColumnDefinitions="150,20" ColumnSpacing="12">
                <Label Text="Onko kissa raskaana?" Grid.Column="0"
                       VerticalTextAlignment="Center"/>
                <CheckBox x:Name="isPregnantChecked" 
                          IsChecked="{Binding IsPregnant}" 
                          Grid.Column="1" HeightRequest="20" WidthRequest="20"
                          BackgroundColor="{StaticResource PrimaryDark}"/>
            </Grid>


            <!--Raskauden tiedot näkyviin vain jos raskaus on käynnissä-->
            <VerticalStackLayout IsVisible="{Binding IsPregnant}" Spacing="15">
                <Label Text="Raskauden tiedot: " FontSize="20" FontAttributes="Bold" />
                <Label Text="{Binding Cat.CurrentPregnancy.PregnancyDate, StringFormat='Raskauspäivä: {0}'}" />
                <Label Text="{Binding Cat.CurrentPregnancy.Trimester, StringFormat='Käynnissä oleva kolmannes: {0}'}" />
                <Label Text="{Binding Cat.CurrentPregnancy.DueDate, StringFormat='Laskettu aika: {0:d}'}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Label Text="Astutuspäivä" Grid.Column="0"/>
                    <DatePicker x:Name="matingDatePicker"
                                Date="{Binding MatingDate}" 
                                MaximumDate="{x:Static sys:DateTime.Today}" 
                                MinimumDate="{Binding MinimumMatingDate}"
                                Grid.Column="1"/>
                </Grid>

                <Button Text="Päivitä raskauden tiedot"
                        Command="{Binding UpdatePregnancyCommand}" />


            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="Black"/>
            
            <Grid RowDefinitions="Auto" ColumnDefinitions="*,*">

                <Button Text="Muokkaa" Command="{Binding EditCatCommand}"
                WidthRequest="170"
                Grid.Row="0" 
                Grid.Column="0"/>
                <Button Text="Poista" Command="{Binding DeleteCatCommand}"
                WidthRequest="170"
                Grid.Row="0"  
                Grid.Column="1"/>

            </Grid>
            <Button Text="Takaisin" Command="{Binding GoBackCommand}" Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>